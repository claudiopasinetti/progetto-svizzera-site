---
import Base from '../layouts/Base.astro';
---

<Base
  title="Testimonianze"
  description="Le parole degli infermieri italiani che hanno completato il percorso Progetto Svizzera e lavorano in Svizzera tedesca."
>
  <section class="mx-auto max-w-5xl px-4 py-24 md:px-6">
    <h1 class="font-display text-5xl font-bold tracking-tight text-brand-primary md:text-6xl">
      Testimonianze
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-brand-ink/80">
      Le storie dirette di chi ha fatto il percorso prima di te.
    </p>

    <div class="mt-16 rounded-lg border border-dashed border-brand-border bg-brand-muted p-6 text-sm text-brand-muted-foreground">
      <strong>Placeholder Blocco 1.</strong> Video testimonianze + carousel + WhatsApp floating
      button in Blocco 4.
    </div>
  </section>
</Base>
