---
import { Image } from 'astro:assets';
import BaseV2 from '../../layouts/BaseV2.astro';
import HeroBand from '../../components/v2/HeroBand.astro';
import CtaBand from '../../components/v2/CtaBand.astro';
import SectionHeader from '../../components/v2/SectionHeader.astro';
import Stripe from '../../components/v2/Stripe.astro';
import { CASTING } from '../../data/config';
import journeyBg from '../../assets/swiss/swiss-train-bernina.jpg';
import operatingRoom from '../../assets/swiss/operating-room.jpg';
import selectionDay from '../../assets/swiss/step-1-selezione.jpg';
import contractAdhesion from '../../assets/swiss/step-2-adesione.jpg';
import germanOnline from '../../assets/swiss/step-3-tedesco-a1a2.jpg';
import swissRedCross from '../../assets/swiss/step-4-srk-documenti.jpg';
import germanNursing from '../../assets/swiss/step-5-tedesco-b1b2.jpg';
import germanCv from '../../assets/swiss/step-6-cv-colloquio.jpg';
import signingContract from '../../assets/swiss/step-7-contratto-onboarding.jpg';

const title = 'Il tuo percorso';
const description = 'Le 7 fasi del percorso Progetto Svizzera: dalla selezione alla firma del contratto in clinica. 7 mesi totali, formazione strutturata.';

const steps = [
  { n: 1, title: 'Giornata di selezione + colloquio', duration: 'mezza giornata · online', body: 'Presentazione del progetto + colloquio individuale. Sono presenti colleghe e colleghi già in Svizzera. Niente test, è una conversazione.', image: selectionDay },
  { n: 2, title: 'Adesione al progetto', duration: 'entro 5-7 giorni dal casting', body: 'Se idonea, ricevi via email l\'Accordo di Adesione. Lo firmi, e parte il percorso.', image: contractAdhesion },
  { n: 3, title: 'Tedesco A1/A2', duration: '12 settimane', body: 'Corsi intensivi online. Verifiche finali per accedere al livello successivo. Lessico medico introdotto da subito.', image: germanOnline },
  { n: 4, title: 'Documenti + riconoscimento titolo SRK', duration: 'in parallelo · fino a 4 mesi', body: 'Avvio pratiche per il riconoscimento del titolo presso la Croce Rossa Svizzera. Ti seguiamo passo per passo: cosa serve, dove inviare, cosa aspettarti.', image: swissRedCross },
  { n: 5, title: 'Tedesco B1/B2 settoriale', duration: '12 settimane', body: 'Corso specialistico: lessico clinico, conversazione coi pazienti, scrittura cartella infermieristica. Si lavora anche sui colloqui.', image: germanNursing },
  { n: 6, title: 'CV in tedesco + colloquio in clinica', duration: 'da fine mese 6', body: 'Redazione del CV tedesco, video di presentazione, candidatura presso le cliniche partner. Colloqui individuali con le strutture interessate.', image: germanCv },
  { n: 7, title: 'Contratto + trasferimento + onboarding', duration: 'mese 7 + 3 mesi inserimento', body: 'Firmi il contratto direttamente con la clinica scelta. Onboarding linguistico (10 settimane in clinica) per consolidare il tedesco specialistico del tuo reparto.', image: signingContract },
];

---

<BaseV2 title={title} description={description}>
  <HeroBand image={journeyBg} alt="Paesaggio svizzero" eyebrow="Il percorso, mese per mese" minHeight="560px">
    <h1 class="ps-display ps-display-lg" style="max-width: 1000px; color: var(--ps-on-dark);">
      7 mesi.<br />
      <span style="color: var(--ps-secondary);">7 fasi.</span>
    </h1>
    <p style="margin: 40px 0 0; max-width: 640px; font-size: 18px; line-height: 1.6; color: var(--ps-body-strong); font-weight: 300;">
      Dal casting al primo turno in reparto. Niente promesse rapide: il percorso dura quanto serve
      a prepararti seriamente. Il {CASTING.stats.completionRate}% di chi lo completa firma un contratto.
    </p>
  </HeroBand>

  <Stripe />

  <section style="background: var(--ps-canvas);">
    <div class="ps-container" style="padding-top: 96px; padding-bottom: 96px;">
      <SectionHeader eyebrow="Le 7 fasi" title="Dal casting al primo turno." />
      <ol style="list-style: none; padding: 0; margin: 64px 0 0; display: flex; flex-direction: column; gap: 24px;">
        {steps.map((s, idx) => {
          const isEven = idx % 2 === 0;
          return (
            <li style="background: var(--ps-canvas-card); display: grid; grid-template-columns: 1fr; gap: 0;">
              <div style={`display: grid; grid-template-columns: 1fr; gap: 0; ${isEven ? '' : ''}`}>
                <div class="ps-step-grid" data-reverse={!isEven}>
                  <div style="aspect-ratio: 4/3; overflow: hidden; background: var(--ps-canvas);">
                    <Image src={s.image} alt={s.title} loading="lazy" widths={[400, 800]} sizes="(min-width: 768px) 40vw, 100vw" style="width: 100%; height: 100%; object-fit: cover;" />
                  </div>
                  <div style="display: flex; flex-direction: column; justify-content: center; padding: 40px; gap: 16px;">
                    <div style="display: flex; align-items: center; gap: 16px;">
                      <span class="ps-display" style="font-size: 56px; color: var(--ps-secondary); line-height: 1;">0{s.n}</span>
                      <p class="ps-label" style="color: var(--ps-muted);">{s.duration}</p>
                    </div>
                    <h3 class="ps-display" style="font-size: 28px; line-height: 1.2; color: var(--ps-on-dark);">{s.title}</h3>
                    <p class="ps-body ps-body-strong" style="font-size: 15px; line-height: 1.7;">{s.body}</p>
                  </div>
                </div>
              </div>
            </li>
          );
        })}
      </ol>

    </div>
  </section>

  <section style="background: var(--ps-canvas); border-top: 1px solid var(--ps-hairline);">
    <div class="ps-container ps-section" style="text-align: left;">
      <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">Cosa ci differenzia dagli altri?</p>
      <p class="ps-display ps-display-md" style="margin: 32px 0 0; color: var(--ps-on-dark); max-width: 900px;">
        Organizziamo noi i colloqui.<br />
        <span style="color: var(--ps-secondary);">Il contratto lo firmi tu.</span>
      </p>
      <p class="ps-body ps-body-strong" style="margin: 32px 0 0; max-width: 700px; font-size: 17px; line-height: 1.7;">
        Non siamo un'agenzia di collocamento: non vendiamo placement, non prendiamo commissioni
        sul tuo contratto. Siamo una scuola di tedesco settoriale + un coordinamento clinico.
        Lo stipendio che ti propone la struttura svizzera arriva intero sul tuo conto, ogni mese.
      </p>
    </div>
  </section>

  <CtaBand image={operatingRoom} alt="Reparto" headlineMain="Pronta a iniziare il percorso?" headlineAccent={`Casting ${CASTING.nextDateDisplay}.`} />
</BaseV2>

<style>
  .ps-step-grid {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .ps-step-grid {
      grid-template-columns: 2fr 3fr;
    }
    .ps-step-grid[data-reverse="true"] {
      direction: rtl;
    }
    .ps-step-grid[data-reverse="true"] > * {
      direction: ltr;
    }
  }
</style>
