---
import BaseV2 from '../../layouts/BaseV2.astro';
import Stripe from '../../components/v2/Stripe.astro';
import { CONTACTS, WHATSAPP } from '../../data/config';

const title = 'Contatti';
const description = 'Email, telefono, WhatsApp e modulo contatti per parlare con il team Progetto Svizzera prima del casting.';

const channels = [
  { label: 'Email', value: CONTACTS.email, href: `mailto:${CONTACTS.email}`, sub: 'Risposta entro 48h lavorative' },
  { label: 'Telefono', value: CONTACTS.phoneDisplay, href: `tel:${CONTACTS.phone}`, sub: 'Lun-Ven 9-18' },
  { label: 'WhatsApp', value: CONTACTS.phoneDisplay, href: WHATSAPP.linkWithMessage, sub: 'Risposta nelle ore di apertura' },
];

const faq = [
  { q: 'In quanto tempo rispondete?', a: 'Email entro 48h lavorative. WhatsApp e telefono nelle ore di apertura (lun-ven 9-18).' },
  { q: 'Posso scrivere se non sono ancora pronto/a a iscrivermi?', a: 'Certo. Le domande sono utili anche prima dell\'iscrizione. Se non sei pronto/a a candidarti subito, puoi anche iscriverti alla newsletter per ricevere info sui prossimi casting.' },
  { q: 'Posso parlare con qualcuno che ha già fatto il percorso?', a: 'Sì. Durante la giornata di selezione sono sempre presenti colleghe e colleghi già collocati. Se vuoi un contatto prima del casting, scrivici via email/WhatsApp.' },
  { q: 'Posso fissare una call conoscitiva senza casting?', a: 'In linea di massima preferiamo le call durante il casting per equità tra le candidature. Per richieste specifiche scrivici e valutiamo caso per caso.' },
];
---

<BaseV2 title={title} description={description}>
  <section style="background: var(--ps-canvas);">
    <div class="ps-container" style="padding-top: 120px; padding-bottom: 64px;">
      <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">Parla con noi</p>
      <h1 class="ps-display ps-display-lg" style="margin: 32px 0 0; max-width: 1000px; color: var(--ps-on-dark);">
        Contatti.
      </h1>
      <p class="ps-body ps-body-lg ps-body-strong" style="margin: 32px 0 0; max-width: 640px;">
        Scrivici prima del casting, durante o dopo. Senza pressione, senza obblighi.
        Rispondiamo entro 48h lavorative.
      </p>
    </div>
  </section>

  <Stripe />

  <section style="background: var(--ps-canvas);">
    <div class="ps-container" style="padding-top: 80px; padding-bottom: 64px;">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; background: var(--ps-hairline);">
        {channels.map((c) => (
          <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel={c.href.startsWith('http') ? 'noopener noreferrer' : undefined}
             style="background: var(--ps-canvas-card); padding: 40px 32px; display: flex; flex-direction: column; gap: 16px; transition: background 180ms ease;"
             onmouseover="this.style.background='var(--ps-canvas-elevated)'"
             onmouseout="this.style.background='var(--ps-canvas-card)'">
            <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">{c.label}</p>
            <p class="ps-display" style="font-size: 22px; line-height: 1.2; color: var(--ps-on-dark); word-break: break-word;">{c.value}</p>
            <p class="ps-body" style="margin: 0; font-size: 13px;">{c.sub} →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section style="background: var(--ps-canvas-soft); border-top: 1px solid var(--ps-hairline-strong);">
    <div class="ps-container-narrow" style="padding-top: 96px; padding-bottom: 96px;">
      <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">Modulo contatti</p>
      <h2 class="ps-display ps-display-md" style="margin: 24px 0 0; color: var(--ps-on-dark);">
        Oppure scrivici qui.
      </h2>
      <p class="ps-body ps-body-strong" style="margin: 16px 0 32px; font-size: 15px;">
        Compila il modulo, ti rispondiamo via email entro 48h lavorative.
      </p>

      <form action="/api/contact" method="POST" style="display: flex; flex-direction: column; gap: 24px;">
        <div>
          <label class="ps-input-label" for="ct-name">Nome *</label>
          <input id="ct-name" type="text" name="name" required autocomplete="given-name" class="ps-input" />
        </div>
        <div>
          <label class="ps-input-label" for="ct-email">Email *</label>
          <input id="ct-email" type="email" name="email" required autocomplete="email" class="ps-input" />
        </div>
        <div>
          <label class="ps-input-label" for="ct-topic">Di cosa vuoi parlare?</label>
          <select id="ct-topic" name="topic" class="ps-input">
            <option value="info">Info generali sul percorso</option>
            <option value="casting">Casting + iscrizione</option>
            <option value="costi">Costi e tempi</option>
            <option value="srk">Riconoscimento titolo SRK</option>
            <option value="testimonianza">Vorrei parlare con una collega già partita</option>
            <option value="altro">Altro</option>
          </select>
        </div>
        <div>
          <label class="ps-input-label" for="ct-message">Messaggio *</label>
          <textarea id="ct-message" name="message" required rows="5" class="ps-input"></textarea>
        </div>
        <label class="ps-checkbox">
          <input type="checkbox" name="consent" required />
          <span>Acconsento al trattamento dei miei dati per ricevere risposta. <a href="/v2/privacy-policy" style="color: var(--ps-secondary-soft); border-bottom: 1px solid currentColor;">Privacy Policy</a>.</span>
        </label>
        <button type="submit" class="ps-button ps-button-primary" style="align-self: flex-start;">Invia messaggio →</button>
      </form>
    </div>
  </section>

  <section style="background: var(--ps-canvas);">
    <div class="ps-container-narrow" style="padding-top: 96px; padding-bottom: 96px;">
      <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">Domande comuni</p>
      <h2 class="ps-display ps-display-md" style="margin: 24px 0 32px; color: var(--ps-on-dark);">Prima di scriverci.</h2>
      <div>
        {faq.map((item) => (
          <details class="ps-faq">
            <summary>{item.q}</summary>
            <p class="ps-faq-body">{item.a}</p>
          </details>
        ))}
      </div>
      <p class="ps-body" style="margin-top: 32px; font-size: 14px;">
        <a href="/v2/faq" class="ps-link-arrow">Vai a tutte le 17 domande</a>
      </p>
    </div>
  </section>
</BaseV2>
