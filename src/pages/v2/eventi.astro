---
import BaseV2 from '../../layouts/BaseV2.astro';
import HeroBand from '../../components/v2/HeroBand.astro';
import CtaBand from '../../components/v2/CtaBand.astro';
import SectionHeader from '../../components/v2/SectionHeader.astro';
import Stripe from '../../components/v2/Stripe.astro';
import { CASTING } from '../../data/config';
import swissCity from '../../assets/swiss/swiss-city-mountains.jpg';
import operatingRoom from '../../assets/swiss/operating-room.jpg';

const title = 'Selezioni 2026';
const description = 'Il calendario delle selezioni Progetto Svizzera 2026. Eventi passati, prossimo casting, come prepararti.';

const pastEvents = [
  { id: '2025-10', title: 'Selezione online', subtitle: '25 ottobre 2025', location: 'Online', images: ['/uploads/selezione-ottobre-2025-4.png', '/uploads/selezione-ottobre-2025-2.png', '/uploads/selezione-ottobre-2025-3.png'] },
  { id: '2025-06', title: 'Selezione online', subtitle: '13 giugno 2025', location: 'Online', images: ['/uploads/selezione-giugno-2025-3.png', '/uploads/selezione-giugno-2025-2.png', '/uploads/selezione-giugno-2025-1.png'] },
  { id: '2025-03', title: 'Selezione in presenza', subtitle: '22 marzo 2025', location: 'Milano', images: ['/uploads/eventi-marzo-2025-1.jpg', '/uploads/eventi-marzo-2025-2.jpg', '/uploads/eventi-marzo-2025-3.jpg'] },
  { id: '2024-05', title: 'Selezione online', subtitle: '10 maggio 2024', location: 'Online', images: ['/uploads/selezione-maggio-2024-1.png'] },
];

const castingSteps = [
  { n: 1, t: 'Presentazione del progetto (~30 min)', b: 'Beatrice presenta le fasi del percorso, le cliniche partner, costi reali, timeline. Sono presenti anche colleghe e colleghi già in Svizzera per rispondere alle tue domande dirette.' },
  { n: 2, t: `Colloquio individuale (~${CASTING.duration})`, b: 'Una conversazione con Beatrice o un membro del team. Capiamo le tue motivazioni, il tuo percorso, le tue domande pratiche. Niente test, niente prove tecniche.' },
  { n: 3, t: 'Risposta entro 5-7 giorni', b: 'Ti scriviamo via email se sei stato/a ammesso/a al percorso o, se non è il momento giusto, ti diciamo perché e quando può esserlo.' },
];
---

<BaseV2 title={title} description={description}>
  <HeroBand image={swissCity} alt="Città svizzera con montagne" eyebrow="Calendario casting" minHeight="520px">
    <h1 class="ps-display ps-display-lg" style="max-width: 1000px; color: var(--ps-on-dark);">
      Selezioni<br />
      <span style="color: var(--ps-secondary);">2026.</span>
    </h1>
    <p class="ps-body ps-body-lg ps-body-strong" style="margin: 32px 0 0; max-width: 640px;">
      Tre selezioni l'anno, sempre online. Ogni selezione comincia con la presentazione del progetto
      + un colloquio individuale con ogni persona. Durata ~{CASTING.duration} a colloquio.
    </p>
  </HeroBand>

  <Stripe />

  <section style="background: var(--ps-canvas);">
    <div class="ps-container ps-section">
      <SectionHeader eyebrow="Date 2026" title="Quando arriva il prossimo." />
      <div style="margin-top: 64px; display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1px; background: var(--ps-hairline);">
        {CASTING.dates2026.map((d) => (
          <article style="background: var(--ps-canvas-card); padding: 48px 40px; display: flex; flex-direction: column; gap: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 16px;">
              <div>
                <p class="ps-label" style="color: var(--ps-muted);">{d.dayLabel}</p>
                <p class="ps-display" style="margin: 12px 0 0; font-size: 32px; line-height: 1.1; color: var(--ps-on-dark);">{d.dateDisplay}</p>
                <p class="ps-body" style="margin: 8px 0 0; font-size: 14px;">{d.modality === 'online' ? 'Online' : 'In presenza'}</p>
              </div>
              <span style={`padding: 6px 12px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; ${d.status === 'open' ? 'background: var(--ps-secondary); color: var(--ps-on-dark);' : 'background: var(--ps-canvas); color: var(--ps-muted); border: 1px solid var(--ps-hairline);'}`}>
                {d.status === 'open' ? 'Iscrizioni aperte' : 'Calendario'}
              </span>
            </div>
            <div>
              <p class="ps-body ps-body-strong" style="margin: 0; font-size: 14px;">
                Deadline iscrizioni: <strong style="color: var(--ps-on-dark);">{d.deadlineDisplay}</strong>
              </p>
              {d.status === 'open' && (
                <p class="ps-body" style="margin: 8px 0 0; font-size: 13px; color: var(--ps-secondary-soft);">
                  Mancano <span data-countdown={`${d.deadlineIso}T23:59:59+02:00`}>—</span>
                </p>
              )}
            </div>
            <a
              href={d.status === 'open' ? '/progetto-svizzera-site/v2/registrazione' : '/progetto-svizzera-site/v2/newsletter'}
              class={`ps-button ${d.status === 'open' ? 'ps-button-primary' : 'ps-button-outline'} ps-button-sm`}
              style="margin-top: auto;"
            >
              {d.status === 'open' ? 'Iscriviti →' : 'Resta aggiornata'}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section style="background: var(--ps-canvas-soft);">
    <div class="ps-container-narrow ps-section">
      <SectionHeader eyebrow="Cos'è una selezione" title="Cosa aspettarti al casting." />
      <ol style="list-style: none; padding: 0; margin: 56px 0 0; display: flex; flex-direction: column; gap: 1px; background: var(--ps-hairline);">
        {castingSteps.map((s) => (
          <li style="background: var(--ps-canvas); padding: 32px; display: flex; gap: 32px; align-items: flex-start;">
            <span class="ps-display" style="font-size: 48px; color: var(--ps-secondary); line-height: 1; flex-shrink: 0;">0{s.n}</span>
            <div>
              <h3 class="ps-display" style="font-size: 22px; line-height: 1.3; color: var(--ps-on-dark);">{s.t}</h3>
              <p class="ps-body ps-body-strong" style="margin: 12px 0 0; font-size: 15px; line-height: 1.6;">{s.b}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section style="background: var(--ps-canvas);">
    <div class="ps-container ps-section">
      <SectionHeader eyebrow="Eventi passati" title={`${CASTING.stats.totalCastings} casting svolti dal ${CASTING.stats.activeSince}.`} body="Selezioni dal 2024." />
      <div style="margin-top: 64px; display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;">
        {pastEvents.map((e) => (
          <article style="background: var(--ps-canvas-card); display: flex; flex-direction: column;">
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--ps-hairline);">
              {e.images.slice(0, 3).map((src) => (
                <div style="aspect-ratio: 1; overflow: hidden; background: var(--ps-canvas);">
                  <img src={src} alt={`${e.title} ${e.subtitle}`} loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" />
                </div>
              ))}
            </div>
            <div style="padding: 24px 28px;">
              <p class="ps-display" style="font-size: 18px; line-height: 1.2; color: var(--ps-on-dark);">{e.title}</p>
              <p class="ps-body" style="margin: 8px 0 0; font-size: 13px;">{e.subtitle} · {e.location}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="ps-body" style="margin-top: 40px; padding: 20px 24px; background: var(--ps-canvas-soft); font-size: 13px; border-left: 4px solid var(--ps-secondary);">
        "Progetto Svizzera" è attivo dal {CASTING.stats.activeSince}. Precedentemente si chiamava "Svizzera Arrivo":
        il progetto si è evoluto mantenendo gli stessi obiettivi.
      </p>
    </div>
  </section>

  <CtaBand image={operatingRoom} alt="Reparto" headlineMain="Vuoi essere alla" headlineAccent="prossima selezione?" />

  <script is:inline>
    function updateCountdown() {
      document.querySelectorAll('[data-countdown]').forEach(function (el) {
        var iso = el.getAttribute('data-countdown');
        var target = new Date(iso).getTime();
        var now = Date.now();
        var diff = target - now;
        if (diff <= 0) { el.textContent = 'iscrizioni chiuse'; return; }
        var days = Math.floor(diff / (1000 * 60 * 60 * 24));
        var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        el.textContent = days + 'g ' + hours + 'h';
      });
    }
    updateCountdown();
    setInterval(updateCountdown, 60000);
  </script>
</BaseV2>
