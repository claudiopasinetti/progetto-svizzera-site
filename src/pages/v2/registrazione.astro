---
import BaseV2 from '../../layouts/BaseV2.astro';
import Stripe from '../../components/v2/Stripe.astro';
import { CASTING, TALLY_FORM_IDS } from '../../data/config';

const title = 'Registrati al casting';
const description = `Iscriviti al casting Progetto Svizzera del ${CASTING.nextDateDisplay}. Online, 20 minuti a persona, deadline iscrizioni ${CASTING.deadlineDisplay}.`;

const steps = [
  { n: 1, t: 'Conferma email entro 1 ora', b: 'Ricevi una conferma automatica con i prossimi step.' },
  { n: 2, t: 'Beatrice ti chiama entro 48h lavorative', b: 'Una breve telefonata per confermare disponibilità e chiarire dubbi prima del casting.' },
  { n: 3, t: 'Inviti al casting + slot orario', b: `Ricevi il link Zoom e l'orario del tuo colloquio individuale per il ${CASTING.nextDateDisplay}.` },
];
const BASE_URL = import.meta.env.BASE_URL;

---

<BaseV2 title={title} description={description}>
  <section style="background: var(--ps-canvas);">
    <div class="ps-container" style="padding-top: 120px; padding-bottom: 64px;">
      <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">Iscrizioni aperte · Deadline {CASTING.deadlineDisplay}</p>
      <h1 class="ps-display ps-display-lg" style="margin: 32px 0 0; max-width: 1000px; color: var(--ps-on-dark);">
        Casting<br />
        <span style="color: var(--ps-secondary);">{CASTING.nextDateDisplay}.</span>
      </h1>
      <p class="ps-body ps-body-lg ps-body-strong" style="margin: 32px 0 0; max-width: 640px;">
        Online, durata circa {CASTING.duration} a persona. Presentiamo il progetto, conosciamo te,
        capiamo insieme se è il percorso giusto. Niente test, niente esame: è una conversazione.
      </p>

      <div style="margin-top: 48px; padding: 32px; background: var(--ps-canvas-card); display: flex; flex-wrap: wrap; gap: 32px; align-items: center; justify-content: space-between;">
        <div>
          <p class="ps-label" style="color: var(--ps-muted);">Mancano alla deadline</p>
          <p class="ps-display" style="margin-top: 8px; font-size: 36px; color: var(--ps-on-dark); font-feature-settings: 'tnum';" data-countdown={CASTING.deadlineIso}>—</p>
          <p class="ps-body" style="margin-top: 4px; font-size: 13px;">Iscrizioni aperte fino al {CASTING.deadlineDisplay}</p>
        </div>
        <a href="#modulo" class="ps-button ps-button-primary">Vai al modulo →</a>
      </div>
    </div>
  </section>

  <Stripe />

  <section style="background: var(--ps-canvas-soft);">
    <div class="ps-container-narrow" style="padding-top: 96px; padding-bottom: 96px;">
      <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">Cosa succede dopo</p>
      <h2 class="ps-display ps-display-md" style="margin: 24px 0 0; color: var(--ps-on-dark);">Tre step, nessuna sorpresa.</h2>

      <ol style="list-style: none; padding: 0; margin: 56px 0 0; display: flex; flex-direction: column; gap: 1px; background: var(--ps-hairline);">
        {steps.map((s) => (
          <li style="background: var(--ps-canvas); padding: 32px; display: flex; gap: 32px; align-items: flex-start;">
            <span class="ps-display" style="font-size: 48px; color: var(--ps-secondary); line-height: 1; flex-shrink: 0;">0{s.n}</span>
            <div>
              <h3 class="ps-display" style="font-size: 22px; line-height: 1.3; color: var(--ps-on-dark);">{s.t}</h3>
              <p class="ps-body ps-body-strong" style="margin: 12px 0 0; font-size: 15px; line-height: 1.6;">{s.b}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="ps-body" style="margin-top: 32px; padding: 20px 24px; background: var(--ps-canvas-card); font-size: 14px; border-left: 4px solid var(--ps-secondary);">
        Il modulo dura circa 5 minuti, sono ~10 domande. Non ti chiediamo documenti in questa fase.
        I tuoi dati restano riservati e non vengono condivisi con terzi.
      </p>
    </div>
  </section>

  <section id="modulo" style="background: var(--ps-canvas);">
    <div class="ps-container-narrow" style="padding-top: 96px; padding-bottom: 96px;">
      <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">Modulo di iscrizione</p>
      <h2 class="ps-display ps-display-md" style="margin: 24px 0 32px; color: var(--ps-on-dark);">Compila il modulo.</h2>

      <iframe
        data-tally-src={`https://tally.so/embed/${TALLY_FORM_IDS.registration}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1`}
        loading="lazy"
        width="100%"
        height="600"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        title="Registrazione Casting — Progetto Svizzera"
        style="background: var(--ps-canvas-card); border: 1px solid var(--ps-hairline);"
      ></iframe>
    </div>
  </section>

  <section style="background: var(--ps-canvas-soft); border-top: 1px solid var(--ps-hairline);">
    <div class="ps-container-narrow" style="padding-top: 80px; padding-bottom: 80px; text-align: center;">
      <h2 class="ps-display ps-display-md" style="color: var(--ps-on-dark);">
        Non sei pronto/a a iscriverti adesso?
      </h2>
      <p class="ps-body ps-body-lg ps-body-strong" style="margin: 24px auto 0; max-width: 640px;">
        Va benissimo. Il casting di {CASTING.nextDateDisplay} è uno dei tre del 2026.
        Se vuoi seguire il progetto e ricevere info sui prossimi senza pressione, lascia solo l'email.
      </p>
      <a href={`${BASE_URL}v2/newsletter`} class="ps-button ps-button-outline" style="margin-top: 40px;">
        Iscriviti alla newsletter
      </a>
    </div>
  </section>

  <script is:inline>
    (function () {
      var params = new URLSearchParams(window.location.search);
      var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid', 'msclkid'];
      var iframe = document.querySelector('iframe[data-tally-src]');
      if (!iframe) return;
      try {
        var url = new URL(iframe.dataset.tallySrc);
        var added = 0;
        keys.forEach(function (k) {
          var v = params.get(k);
          if (v) { url.searchParams.set(k, v); added++; }
        });
        if (added > 0) iframe.dataset.tallySrc = url.toString();
      } catch (e) {}
    })();
  </script>
  <script src="https://tally.so/widgets/embed.js" async is:inline></script>
  <script is:inline>
    function updateCountdown() {
      document.querySelectorAll('[data-countdown]').forEach(function (el) {
        var iso = el.getAttribute('data-countdown');
        var target = new Date(iso).getTime();
        var now = Date.now();
        var diff = target - now;
        if (diff <= 0) { el.textContent = 'Iscrizioni chiuse'; return; }
        var days = Math.floor(diff / (1000 * 60 * 60 * 24));
        var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        el.textContent = days + 'g ' + hours + 'h ' + minutes + 'm';
      });
    }
    updateCountdown();
    setInterval(updateCountdown, 60000);
  </script>
</BaseV2>
