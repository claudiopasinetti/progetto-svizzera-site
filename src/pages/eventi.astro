---
import Base from '../layouts/Base.astro';
import { CASTING } from '../data/config';
---

<Base
  title="Eventi"
  description={`Casting e selezioni Progetto Svizzera 2026. Prossimo casting online: ${CASTING.nextDateDisplay}.`}
>
  <section class="mx-auto max-w-5xl px-4 py-24 md:px-6">
    <h1 class="font-display text-5xl font-bold tracking-tight text-brand-primary md:text-6xl">
      Eventi e selezioni
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-brand-ink/80">
      Il prossimo casting online è il <strong>{CASTING.nextDateDisplay}</strong>.
    </p>

    <div class="mt-16 rounded-lg border border-dashed border-brand-border bg-brand-muted p-6 text-sm text-brand-muted-foreground">
      <strong>Placeholder Blocco 1.</strong> Timeline eventi 2026 + countdown island +
      storico selezioni passate in Blocco 2.
    </div>
  </section>
</Base>
