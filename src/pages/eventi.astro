---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { CASTING } from '../data/config';
import { PRIMARY_CTA, SECONDARY_CTA } from '../data/navigation';
import CountdownCasting from '../components/CountdownCasting.tsx';
import FadeIn from '../components/FadeIn.tsx';
import swissCity from '../assets/swiss/swiss-city-mountains.jpg';

const title = 'Eventi e selezioni';
const description = 'Il calendario delle selezioni Progetto Svizzera 2026. Eventi passati con foto reali, prossimo casting, come prepararti.';

/* TODO V8 — selezioni passate, foto da archivio Barbara (file in /uploads/) */
const pastEvents = [
  { id: '2025-10', title: 'Selezione online', subtitle: '25 ottobre 2025', location: 'Online', images: ['/uploads/selezione-ottobre-2025-4.png', '/uploads/selezione-ottobre-2025-2.png', '/uploads/selezione-ottobre-2025-3.png'] },
  { id: '2025-06', title: 'Selezione online', subtitle: '13 giugno 2025', location: 'Online', images: ['/uploads/selezione-giugno-2025-3.png', '/uploads/selezione-giugno-2025-2.png', '/uploads/selezione-giugno-2025-1.png'] },
  { id: '2025-03', title: 'Selezione in presenza', subtitle: '22 marzo 2025', location: 'Milano', images: ['/uploads/eventi-marzo-2025-1.jpg', '/uploads/eventi-marzo-2025-2.jpg', '/uploads/eventi-marzo-2025-3.jpg'] },
  { id: '2024-05', title: 'Selezione online', subtitle: '10 maggio 2024', location: 'Online', images: ['/uploads/selezione-maggio-2024-1.png'] },
];
---

<Base title={title} description={description}>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={swissCity}
        alt="Città svizzera con montagne"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/85 to-white/70"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 py-24 md:px-6 md:py-28">
      <FadeIn client:load>
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-secondary">Calendario</p>
        <h1 class="mt-3 font-display text-4xl font-bold text-brand-primary md:text-6xl">
          Selezioni 2026
        </h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-brand-ink/85">
          Tre selezioni l'anno, sempre online. Ogni selezione comincia con la presentazione del progetto
          + un colloquio individuale con ciascuna candidata. Durata ~{CASTING.duration} a colloquio.
        </p>
      </FadeIn>
    </div>
  </section>

  {/* Date 2026 */}
  <section class="bg-white py-16">
    <div class="mx-auto max-w-5xl px-4 md:px-6">
      <div class="grid gap-6 md:grid-cols-2">
        {CASTING.dates2026.map((d, idx) => (
          <FadeIn client:visible delay={idx * 0.1}>
            <article class:list={[
              'rounded-lg border bg-white p-6 transition-all hover:-translate-y-1 hover:shadow-xl md:p-8',
              d.status === 'open'
                ? 'border-brand-secondary/40 shadow-md'
                : 'border-brand-border'
            ]}>
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-brand-muted-foreground">{d.dayLabel}</p>
                  <p class="mt-1 font-display text-2xl font-bold text-brand-primary">{d.dateDisplay}</p>
                  <p class="mt-1 text-sm text-brand-muted-foreground">{d.modality === 'online' ? 'Online' : 'In presenza'}</p>
                </div>
                <span class:list={[
                  'rounded-full px-3 py-1 text-xs font-semibold',
                  d.status === 'open' ? 'bg-brand-secondary/10 text-brand-secondary' : 'bg-brand-muted text-brand-muted-foreground'
                ]}>
                  {d.status === 'open' ? 'Iscrizioni aperte' : 'Calendario'}
                </span>
              </div>

              <p class="mt-6 text-sm text-brand-ink/75">
                Deadline iscrizioni: <strong>{d.deadlineDisplay}</strong>
              </p>

              {d.status === 'open' && (
                <div class="mt-2 text-sm text-brand-secondary">
                  Mancano <CountdownCasting client:idle targetIso={`${d.deadlineIso}T23:59:59+02:00`} expiredLabel="iscrizioni chiuse" />
                </div>
              )}

              <div class="mt-6">
                <a
                  href={d.status === 'open' ? PRIMARY_CTA.href : SECONDARY_CTA.href}
                  class:list={[
                    'inline-flex items-center justify-center rounded-md px-5 py-2.5 text-sm font-semibold transition-all hover:scale-[1.02]',
                    d.status === 'open'
                      ? 'bg-brand-secondary text-white shadow-md hover:bg-brand-secondary/90'
                      : 'border border-brand-border bg-white text-brand-ink hover:border-brand-primary hover:text-brand-primary'
                  ]}
                >
                  {d.status === 'open' ? 'Iscriviti →' : 'Resta aggiornata sui prossimi'}
                </a>
              </div>
            </article>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  {/* Cos'è una selezione */}
  <section class="bg-brand-muted/40 py-20 md:py-24">
    <div class="mx-auto max-w-3xl px-4 md:px-6">
      <FadeIn client:visible>
        <h2 class="font-display text-3xl font-bold text-brand-primary md:text-4xl">
          Cos'è una selezione, in pratica
        </h2>
      </FadeIn>
      <ol class="mt-8 space-y-5 text-brand-ink/85">
        {[
          { n: 1, t: 'Presentazione del progetto (~30 min)', b: 'Beatrice presenta le fasi del percorso, le cliniche partner, costi reali, timeline. Sono presenti anche colleghe già in Svizzera per rispondere alle tue domande dirette.' },
          { n: 2, t: `Colloquio individuale (~${CASTING.duration})`, b: 'Una conversazione con Beatrice o un membro del team. Capiamo le tue motivazioni, il tuo percorso, le tue domande pratiche. Niente test, niente prove tecniche.' },
          { n: 3, t: 'Risposta entro 5-7 giorni', b: 'Ti scriviamo via email se sei stata ammessa al percorso o, se non è il momento giusto, ti diciamo perché e quando può esserlo.' },
        ].map((s, idx) => (
          <FadeIn client:visible delay={idx * 0.08}>
            <li class="flex gap-4">
              <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-brand-secondary text-sm font-semibold text-white">{s.n}</span>
              <div>
                <p class="font-semibold text-brand-ink">{s.t}</p>
                <p class="mt-1 text-sm text-brand-ink/70">{s.b}</p>
              </div>
            </li>
          </FadeIn>
        ))}
      </ol>
    </div>
  </section>

  {/* Eventi passati gallery */}
  <section class="bg-white py-20 md:py-24">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <FadeIn client:visible>
        <h2 class="font-display text-3xl font-bold text-brand-primary md:text-4xl">
          Eventi passati
        </h2>
        <p class="mt-3 text-brand-ink/75">
          Selezioni svolte dal 2024. {CASTING.stats.totalCastings} casting totali dal 2018.
        </p>
      </FadeIn>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {pastEvents.map((e, idx) => (
          <FadeIn client:visible delay={idx * 0.08}>
            <article class="group overflow-hidden rounded-lg border border-brand-border bg-white transition-all hover:-translate-y-1 hover:shadow-lg">
              <div class="grid grid-cols-3 gap-1 bg-brand-muted">
                {e.images.slice(0, 3).map((src) => (
                  <div class="aspect-square overflow-hidden">
                    <img
                      src={src}
                      alt={`${e.title} ${e.subtitle}`}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                ))}
              </div>
              <div class="p-5">
                <p class="font-display text-lg font-semibold text-brand-primary">{e.title}</p>
                <p class="text-sm text-brand-ink/75">{e.subtitle} · {e.location}</p>
              </div>
            </article>
          </FadeIn>
        ))}
      </div>

      <FadeIn client:visible>
        <p class="mt-10 rounded-md bg-brand-muted/50 p-5 text-sm text-brand-ink/75">
          "Progetto Svizzera" è attivo dal 2018. Precedentemente si chiamava "Svizzera Arrivo":
          il progetto si è evoluto mantenendo gli stessi obiettivi.
        </p>
      </FadeIn>
    </div>
  </section>

  {/* CTA finale */}
  <section class="bg-brand-primary py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center md:px-6">
      <FadeIn client:visible>
        <h2 class="font-display text-2xl font-bold text-white md:text-3xl">
          Vuoi essere alla prossima selezione?
        </h2>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a
            href={PRIMARY_CTA.href}
            class="inline-flex items-center justify-center rounded-md bg-brand-secondary px-6 py-3 text-base font-semibold text-white shadow-lg transition-all hover:scale-105 hover:bg-brand-secondary/90"
          >
            {PRIMARY_CTA.label}
          </a>
          <a
            href={SECONDARY_CTA.href}
            class="inline-flex items-center justify-center rounded-md border border-white/30 bg-white/10 px-6 py-3 text-base font-semibold text-white transition-all hover:scale-105 hover:bg-white/20"
          >
            {SECONDARY_CTA.label}
          </a>
        </div>
      </FadeIn>
    </div>
  </section>
</Base>
