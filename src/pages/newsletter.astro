---
import Base from '../layouts/Base.astro';
import { CASTING } from '../data/config';
import { PRIMARY_CTA } from '../data/navigation';
import NewsletterForm from '../components/NewsletterForm.tsx';

const title = 'Resta aggiornata';
const description = 'Iscriviti alla newsletter Progetto Svizzera: una email al mese, info sui prossimi casting, storie di chi ha completato il percorso. Niente spam.';
---

<Base title={title} description={description}>
  <section class="bg-gradient-to-b from-brand-muted/30 to-white">
    <div class="mx-auto max-w-3xl px-4 py-20 md:px-6 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-secondary">Nessuna pressione</p>
      <h1 class="mt-3 font-display text-4xl font-bold text-brand-primary md:text-5xl">
        Resta aggiornata sui prossimi casting
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-brand-ink/80">
        Se non sei pronta a iscriverti adesso, va benissimo. Lascia solo l'email:
        ti scriviamo prima del prossimo casting con un riassunto onesto e senza fretta.
      </p>
    </div>
  </section>

  <section class="bg-white py-12">
    <div class="mx-auto grid max-w-5xl gap-12 px-4 md:grid-cols-[3fr_2fr] md:px-6">
      <div>
        <h2 class="font-display text-2xl font-bold text-brand-primary md:text-3xl">
          Cosa riceverai
        </h2>
        <ul class="mt-6 space-y-4 text-brand-ink/85">
          <li class="flex gap-3"><span class="text-brand-secondary mt-1" aria-hidden="true">•</span><span><strong>Una email al mese</strong>, mai di più. Niente spam, niente promo.</span></li>
          <li class="flex gap-3"><span class="text-brand-secondary mt-1" aria-hidden="true">•</span><span><strong>Info sui prossimi casting</strong>, tipicamente 4-6 settimane prima della deadline iscrizioni.</span></li>
          <li class="flex gap-3"><span class="text-brand-secondary mt-1" aria-hidden="true">•</span><span><strong>Storie di chi ha completato il percorso</strong>: come è andata, cosa si poteva fare meglio, com'è la vita in CH.</span></li>
          <li class="flex gap-3"><span class="text-brand-secondary mt-1" aria-hidden="true">•</span><span><strong>Aggiornamenti reali sul mestiere</strong>: stipendi, ratio paziente-infermiere, novità riconoscimento titolo SRK.</span></li>
          <li class="flex gap-3"><span class="text-brand-secondary mt-1" aria-hidden="true">•</span><span><strong>Disiscrizione in 1 click</strong> in fondo a ogni email.</span></li>
        </ul>

        <p class="mt-8 rounded-md bg-brand-muted/50 p-4 text-sm text-brand-ink/80">
          Se invece sai già che vuoi candidarti al casting di {CASTING.nextDateDisplay},
          <a href={PRIMARY_CTA.href} class="font-semibold text-brand-secondary hover:underline">vai direttamente all'iscrizione</a>.
        </p>
      </div>

      <div class="rounded-lg border border-brand-border bg-white p-6 md:p-8">
        {/* TODO Wave 2 — endpoint /api/newsletter + provider TBD (Brevo o CRM-native Eumedica) */}
        <NewsletterForm client:visible />
      </div>
    </div>
  </section>
</Base>
