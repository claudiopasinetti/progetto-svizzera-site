---
import Base from '../layouts/Base.astro';
import { CONTACTS, WHATSAPP } from '../data/config';
import { PRIMARY_CTA, SECONDARY_CTA } from '../data/navigation';
import FAQAccordion from '../components/FAQAccordion.tsx';

const title = 'Contatti';
const description = 'Email, telefono, WhatsApp e modulo contatti per parlare con il team Progetto Svizzera prima del casting.';

const faq = [
  { q: 'In quanto tempo rispondete?', a: 'Email entro 48h lavorative. WhatsApp e telefono nelle ore di apertura (lun-ven 9-18).' },
  { q: 'Posso scrivere se non sono ancora pronta a iscrivermi?', a: 'Certo. Le domande sono utili anche prima dell\'iscrizione. Se non sei pronta a candidarti subito, puoi anche iscriverti alla newsletter per ricevere info sui prossimi casting.' },
  { q: 'Posso parlare con qualcuna che ha già fatto il percorso?', a: 'Sì. Durante la giornata di selezione sono sempre presenti colleghe già collocate. Se vuoi un contatto prima del casting, scrivici via email/WhatsApp.' },
  { q: 'Posso fissare una call conoscitiva senza casting?', a: 'In linea di massima preferiamo le call durante il casting per equità tra candidate. Per richieste specifiche scrivici e valutiamo caso per caso.' },
];
---

<Base title={title} description={description}>
  <section class="bg-gradient-to-b from-brand-muted/30 to-white">
    <div class="mx-auto max-w-5xl px-4 py-20 md:px-6 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-secondary">Parla con noi</p>
      <h1 class="mt-3 font-display text-4xl font-bold text-brand-primary md:text-5xl">
        Contatti
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-brand-ink/80">
        Scrivici prima del casting, durante o dopo. Senza pressione, senza obblighi.
        Rispondiamo entro 48h lavorative.
      </p>
    </div>
  </section>

  <section class="bg-white py-12">
    <div class="mx-auto grid max-w-5xl gap-6 px-4 md:grid-cols-3 md:px-6">
      <a
        href={`mailto:${CONTACTS.email}`}
        class="rounded-lg border border-brand-border bg-white p-6 transition-shadow hover:shadow-md"
      >
        <div class="text-2xl">📧</div>
        <h3 class="mt-3 font-display font-semibold text-brand-primary">Email</h3>
        <p class="mt-1 text-sm text-brand-ink/70 break-all">{CONTACTS.email}</p>
        <p class="mt-2 text-xs text-brand-muted-foreground">Risposta entro 48h lavorative</p>
      </a>

      <a
        href={`tel:${CONTACTS.phone}`}
        class="rounded-lg border border-brand-border bg-white p-6 transition-shadow hover:shadow-md"
      >
        <div class="text-2xl">📞</div>
        <h3 class="mt-3 font-display font-semibold text-brand-primary">Telefono</h3>
        <p class="mt-1 text-sm text-brand-ink/70">{CONTACTS.phoneDisplay}</p>
        <p class="mt-2 text-xs text-brand-muted-foreground">Lun-Ven 9-18</p>
      </a>

      <a
        href={WHATSAPP.linkWithMessage}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg border border-brand-border bg-white p-6 transition-shadow hover:shadow-md"
      >
        <div class="text-2xl">💬</div>
        <h3 class="mt-3 font-display font-semibold text-brand-primary">WhatsApp</h3>
        <p class="mt-1 text-sm text-brand-ink/70">{CONTACTS.phoneDisplay}</p>
        <p class="mt-2 text-xs text-brand-muted-foreground">Risposta nelle ore di apertura</p>
      </a>
    </div>
  </section>

  <section class="bg-white py-12">
    <div class="mx-auto max-w-2xl px-4 md:px-6">
      <h2 class="font-display text-2xl font-bold text-brand-primary md:text-3xl">
        Oppure scrivici qui
      </h2>
      <p class="mt-2 text-sm text-brand-ink/70">
        Compila il modulo, ti rispondiamo via email entro 48h lavorative.
      </p>

      {/* TODO Wave 2 — endpoint /api/contact + Resend integration */}
      <form action="/api/contact" method="POST" class="mt-8 space-y-4">
        <div>
          <label for="ct-name" class="mb-1 block text-sm font-medium text-brand-ink">Nome <span class="text-brand-secondary">*</span></label>
          <input id="ct-name" type="text" name="name" required autocomplete="given-name" class="w-full rounded-md border border-brand-border bg-white px-3 py-2 text-sm focus:border-brand-secondary focus:outline-none focus:ring-2 focus:ring-brand-secondary/20" />
        </div>
        <div>
          <label for="ct-email" class="mb-1 block text-sm font-medium text-brand-ink">Email <span class="text-brand-secondary">*</span></label>
          <input id="ct-email" type="email" name="email" required autocomplete="email" class="w-full rounded-md border border-brand-border bg-white px-3 py-2 text-sm focus:border-brand-secondary focus:outline-none focus:ring-2 focus:ring-brand-secondary/20" />
        </div>
        <div>
          <label for="ct-topic" class="mb-1 block text-sm font-medium text-brand-ink">Di cosa vuoi parlare?</label>
          <select id="ct-topic" name="topic" class="w-full rounded-md border border-brand-border bg-white px-3 py-2 text-sm focus:border-brand-secondary focus:outline-none focus:ring-2 focus:ring-brand-secondary/20">
            <option value="info">Info generali sul percorso</option>
            <option value="casting">Casting + iscrizione</option>
            <option value="costi">Costi e tempi</option>
            <option value="srk">Riconoscimento titolo SRK</option>
            <option value="testimonianza">Vorrei parlare con una collega già partita</option>
            <option value="altro">Altro</option>
          </select>
        </div>
        <div>
          <label for="ct-message" class="mb-1 block text-sm font-medium text-brand-ink">Messaggio <span class="text-brand-secondary">*</span></label>
          <textarea id="ct-message" name="message" required rows="4" class="w-full rounded-md border border-brand-border bg-white px-3 py-2 text-sm focus:border-brand-secondary focus:outline-none focus:ring-2 focus:ring-brand-secondary/20"></textarea>
        </div>
        <label class="flex items-start gap-3 text-sm text-brand-ink/85">
          <input type="checkbox" name="consent" required class="mt-1 h-4 w-4 rounded border-brand-border text-brand-secondary focus:ring-brand-secondary/40" />
          <span>Acconsento al trattamento dei miei dati per ricevere risposta. <a href="/privacy-policy" class="font-semibold text-brand-secondary hover:underline">Privacy</a>.</span>
        </label>
        <button type="submit" class="inline-flex w-full items-center justify-center rounded-md bg-brand-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-primary/90 sm:w-auto">
          Invia messaggio
        </button>
      </form>
    </div>
  </section>

  <section class="bg-brand-muted/40 py-16">
    <div class="mx-auto max-w-3xl px-4 md:px-6">
      <h2 class="font-display text-2xl font-bold text-brand-primary md:text-3xl">
        Domande comuni prima di scriverci
      </h2>
      <div class="mt-8">
        <FAQAccordion client:visible items={faq} />
      </div>
      <p class="mt-6 text-center text-sm text-brand-muted-foreground">
        <a href="/faq" class="font-semibold text-brand-secondary hover:underline">Vai a tutte le 17 domande →</a>
      </p>
    </div>
  </section>

  <section class="bg-white py-12">
    <div class="mx-auto max-w-3xl px-4 text-center md:px-6">
      <p class="text-base text-brand-ink/75">
        Sai già che vuoi candidarti? <a href={PRIMARY_CTA.href} class="font-semibold text-brand-secondary hover:underline">{PRIMARY_CTA.label}</a>.
        Vuoi solo restare aggiornata? <a href={SECONDARY_CTA.href} class="font-semibold text-brand-primary hover:underline">{SECONDARY_CTA.label}</a>.
      </p>
    </div>
  </section>
</Base>
