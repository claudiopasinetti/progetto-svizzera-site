---
import Base from '../layouts/Base.astro';
import { CONTACTS } from '../data/config';
---

<Base
  title="Contatti"
  description="Contatta Progetto Svizzera: email, telefono, WhatsApp per informazioni sul percorso e sul casting per infermieri italiani."
>
  <section class="mx-auto max-w-5xl px-4 py-24 md:px-6">
    <h1 class="font-display text-5xl font-bold tracking-tight text-brand-primary md:text-6xl">
      Contatti
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-brand-ink/80">
      Siamo disponibili via email, telefono e WhatsApp nei giorni lavorativi.
    </p>

    <dl class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
      <div class="rounded-lg border border-brand-border bg-white p-6">
        <dt class="text-xs font-semibold uppercase tracking-wider text-brand-muted-foreground">Email</dt>
        <dd class="mt-2"><a href={`mailto:${CONTACTS.email}`} class="font-medium text-brand-primary hover:text-brand-secondary">{CONTACTS.email}</a></dd>
      </div>
      <div class="rounded-lg border border-brand-border bg-white p-6">
        <dt class="text-xs font-semibold uppercase tracking-wider text-brand-muted-foreground">Telefono</dt>
        <dd class="mt-2"><a href={`tel:${CONTACTS.phone}`} class="font-medium text-brand-primary hover:text-brand-secondary">{CONTACTS.phoneDisplay}</a></dd>
      </div>
      <div class="rounded-lg border border-brand-border bg-white p-6">
        <dt class="text-xs font-semibold uppercase tracking-wider text-brand-muted-foreground">WhatsApp</dt>
        <dd class="mt-2"><a href={CONTACTS.whatsapp} target="_blank" rel="noopener noreferrer" class="font-medium text-brand-primary hover:text-brand-secondary">Scrivici</a></dd>
      </div>
    </dl>

    <div class="mt-16 rounded-lg border border-dashed border-brand-border bg-brand-muted p-6 text-sm text-brand-muted-foreground">
      <strong>Placeholder Blocco 1.</strong> Form contatti (react-hook-form + Zod + endpoint
      Resend) in Blocco 2.
    </div>
  </section>
</Base>
