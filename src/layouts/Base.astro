---
import '../styles/global.css';
import { BRAND, SEO_DEFAULTS } from '../data/config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title = SEO_DEFAULTS.title,
  description = SEO_DEFAULTS.description,
  canonicalPath = Astro.url.pathname,
  noindex = false,
  ogImage = SEO_DEFAULTS.ogImage,
} = Astro.props;

const isDefaultTitle = title === SEO_DEFAULTS.title;
const fullTitle = isDefaultTitle ? title : `${title} — ${BRAND.name}`;
const canonicalUrl = new URL(canonicalPath, BRAND.url).toString();
const ogImageUrl = new URL(ogImage, BRAND.url).toString();
---

<!doctype html>
<html lang={BRAND.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={BRAND.name} />
    <meta property="og:locale" content={BRAND.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content={BRAND.colors.primary} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* TODO(Blocco 5): inject GA4 + GTM + Meta Pixel tags dietro Consent Mode v2 */}
  </head>
  <body class="min-h-screen flex flex-col bg-brand-bg text-brand-ink">
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
