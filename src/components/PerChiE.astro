---
const fitItems = [
  'Hai una laurea triennale in infermieristica',
  'Sei cittadina/o EU (passaporto necessario per il riconoscimento SRK)',
  '25–45 anni, con o senza esperienza ospedaliera',
  'Sei disposta a 7-8 mesi di formazione linguistica strutturata',
  'Vuoi lavorare in reparto come infermiera, non in altri ruoli',
];

const notFitItems = [
  'Cerchi un lavoro in Svizzera entro 3 mesi (i tempi non sono comprimibili)',
  'Vuoi lavorare nel Canton Ticino (siamo focalizzati sulla Svizzera tedesca)',
  'Non sei disposta a studiare il tedesco con costanza nei pomeriggi/serate',
  'Hai bisogno di un contratto a chiamata o stagionale',
  'Cerchi una professione diversa (OSS, ostetrica, medico)',
];
---

<section class="bg-white py-20 md:py-24">
  <div class="mx-auto max-w-5xl px-4 md:px-6">
    <div class="mb-12 max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-secondary">Trasparenza</p>
      <h2 class="mt-2 font-display text-3xl font-bold text-brand-primary md:text-4xl">
        Per chi è il percorso, e per chi non è
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-brand-ink/70">
        Meglio dirselo subito. Non è un percorso veloce, e non funziona per chiunque.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      <div class="rounded-lg border border-brand-success/30 bg-white p-6 md:p-8">
        <h3 class="font-display text-lg font-bold text-brand-success">È per te se…</h3>
        <ul class="mt-4 space-y-2 text-sm text-brand-ink/85">
          {fitItems.map((it) => (
            <li class="flex gap-2"><span class="text-brand-success" aria-hidden="true">✓</span><span>{it}</span></li>
          ))}
        </ul>
      </div>

      <div class="rounded-lg border border-brand-secondary/30 bg-white p-6 md:p-8">
        <h3 class="font-display text-lg font-bold text-brand-secondary">Non è per te se…</h3>
        <ul class="mt-4 space-y-2 text-sm text-brand-ink/85">
          {notFitItems.map((it) => (
            <li class="flex gap-2"><span class="text-brand-secondary" aria-hidden="true">×</span><span>{it}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
