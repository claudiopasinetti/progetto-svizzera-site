---
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  align?: 'left' | 'center';
  size?: 'md' | 'lg';
  maxWidth?: string;
}
const {
  eyebrow,
  title,
  body,
  align = 'left',
  size = 'md',
  maxWidth = '720px',
} = Astro.props;

const sizeClass = size === 'lg' ? 'ps-display-lg' : 'ps-display-md';
const textAlign = align === 'center' ? 'text-align: center;' : '';
const margin = align === 'center' ? 'margin-left: auto; margin-right: auto;' : '';
---

<header style={`${textAlign} max-width: ${align === 'center' ? maxWidth : 'none'}; ${margin}`}>
  {eyebrow && (
    <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0;">{eyebrow}</p>
  )}
  <h2 class={`ps-display ${sizeClass}`} style={`margin: 24px 0 0; max-width: ${align === 'left' ? maxWidth : 'none'}; ${margin} color: var(--ps-on-dark);`}>
    {title}
  </h2>
  {body && (
    <p class="ps-body ps-body-lg" style={`margin: 24px 0 0; max-width: ${align === 'left' ? '640px' : maxWidth}; ${margin}`}>
      {body}
    </p>
  )}
</header>
