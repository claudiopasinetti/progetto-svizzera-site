---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow?: string;
  minHeight?: string;
  overlay?: 'strong' | 'medium' | 'soft';
  align?: 'left' | 'center';
}
const {
  image,
  alt,
  eyebrow,
  minHeight = '600px',
  overlay = 'strong',
  align = 'left',
} = Astro.props;

const overlayGradient = {
  strong: 'linear-gradient(90deg, var(--ps-canvas) 0%, rgba(15,31,53,0.85) 50%, rgba(15,31,53,0.4) 100%)',
  medium: 'linear-gradient(180deg, rgba(15,31,53,0.6) 0%, rgba(15,31,53,0.85) 100%)',
  soft: 'linear-gradient(180deg, rgba(15,31,53,0.5) 0%, rgba(15,31,53,0.7) 50%, var(--ps-canvas) 100%)',
}[overlay];
const opacity = overlay === 'strong' ? 0.55 : overlay === 'medium' ? 0.6 : 0.45;
---

<section style={`position: relative; overflow: hidden; background: var(--ps-canvas); min-height: ${minHeight};`}>
  <div style="position: absolute; inset: 0; z-index: 0;">
    <Image
      src={image}
      alt={alt}
      loading="eager"
      style={`width: 100%; height: 100%; object-fit: cover; opacity: ${opacity};`}
    />
    <div style={`position: absolute; inset: 0; background: ${overlayGradient};`}></div>
  </div>
  <div
    class="ps-container"
    style={`position: relative; z-index: 10; padding-top: 120px; padding-bottom: 120px; min-height: ${minHeight}; display: flex; flex-direction: column; justify-content: center; ${align === 'center' ? 'align-items: center; text-align: center;' : ''}`}
  >
    {eyebrow && (
      <p class="ps-label" style="color: var(--ps-secondary-soft); margin: 0 0 32px;">{eyebrow}</p>
    )}
    <slot />
  </div>
</section>
