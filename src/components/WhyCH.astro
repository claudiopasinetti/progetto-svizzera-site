---
import { Image } from 'astro:assets';
import swissCityReal from '../assets/swiss/swiss-city-real.jpg';
import swissFrancsMoney from '../assets/swiss/swiss-francs-money.jpg';
import operatingRoom from '../assets/swiss/operating-room.jpg';
import teamCollaboration from '../assets/swiss/team-collaboration.jpg';
import swissPension from '../assets/swiss/swiss-pension.jpg';
import signingContract from '../assets/swiss/signing-contract.jpg';
import FadeIn from './FadeIn.tsx';

const items = [
  {
    title: 'Standard di vita elevato',
    body: 'Servizi pubblici e infrastrutture eccellenti, sicurezza, equilibrio tra lavoro e tempo libero.',
    image: swissCityReal,
  },
  {
    title: 'Stipendi tra i più alti d’Europa',
    body: 'Le competenze e l’impegno vengono riconosciuti concretamente: 4.500-6.500 CHF lordi mensili neo-assunta.',
    image: swissFrancsMoney,
  },
  {
    title: 'Sistema sanitario d’eccellenza',
    body: 'Tecnologie avanzate, ratio paziente-infermiere 4:1, condizioni di lavoro che consentono di esercitare la professione.',
    image: operatingRoom,
  },
  {
    title: 'Crescita professionale strutturata',
    body: 'Specializzazioni interne riconosciute e percorsi di carriera continui, finanziati dalle cliniche.',
    image: teamCollaboration,
  },
  {
    title: 'Sistema previdenziale solido',
    body: 'Pensione integrativa svizzera trasparente, una vera tutela per il lungo periodo. Anche da nuovi assunti.',
    image: swissPension,
  },
  {
    title: 'Contratti a tempo indeterminato',
    body: 'Direttamente con la clinica, regolati dalle norme svizzere. Niente intermediazione, niente vincoli.',
    image: signingContract,
  },
];
---

<section class="bg-white py-20 md:py-24">
  <div class="mx-auto max-w-7xl px-4 md:px-6">
    <FadeIn client:visible>
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-secondary">Perché la Svizzera tedesca</p>
      <h2 class="mt-2 max-w-2xl font-display text-3xl font-bold text-brand-primary md:text-4xl">
        Sei differenze concrete che senti già dal primo turno.
      </h2>
    </FadeIn>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {items.map((it, idx) => (
        <FadeIn client:visible delay={idx * 0.08}>
          <article class="group h-full overflow-hidden rounded-lg border border-brand-border bg-white transition-shadow hover:shadow-xl">
            <div class="aspect-[16/10] overflow-hidden bg-brand-muted">
              <Image
                src={it.image}
                alt={it.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                widths={[400, 800]}
                sizes="(min-width: 1024px) 400px, (min-width: 768px) 50vw, 100vw"
              />
            </div>
            <div class="p-6">
              <h3 class="font-display text-lg font-bold text-brand-primary">{it.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-brand-ink/80">{it.body}</p>
            </div>
          </article>
        </FadeIn>
      ))}
    </div>
  </div>
</section>
