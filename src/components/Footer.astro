---
import { BRAND, CONTACTS } from '../data/config';
import { NAV_ITEMS } from '../data/navigation';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-brand-border bg-brand-navy text-white">
  <div class="mx-auto max-w-7xl px-4 py-12 md:px-6 md:py-16">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3 lg:gap-12">
      <div>
        <p class="font-display text-xl font-bold text-white">{BRAND.name}</p>
        <p class="mt-2 max-w-xs text-sm text-white/70">{BRAND.tagline}</p>
      </div>

      <div>
        <h4 class="font-display text-sm font-semibold uppercase tracking-wider text-white/90">
          Informazioni
        </h4>
        <ul class="mt-4 space-y-2 text-sm">
          {NAV_ITEMS.map((item) => (
            <li>
              <a href={item.href} class="text-white/70 transition-colors hover:text-white">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-display text-sm font-semibold uppercase tracking-wider text-white/90">
          Contatti
        </h4>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href={`mailto:${CONTACTS.email}`} class="text-white/70 hover:text-white">
              {CONTACTS.email}
            </a>
          </li>
          <li>
            <a href={`tel:${CONTACTS.phone}`} class="text-white/70 hover:text-white">
              {CONTACTS.phoneDisplay}
            </a>
          </li>
          <li>
            <a
              href={CONTACTS.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/70 hover:text-white"
            >
              WhatsApp
            </a>
          </li>
        </ul>
        <div class="mt-4 flex gap-4">
          <a
            href={CONTACTS.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/70 hover:text-white"
          >
            Instagram
          </a>
          <a
            href={CONTACTS.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/70 hover:text-white"
          >
            Facebook
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start gap-4 border-t border-white/10 pt-8 md:flex-row md:items-center md:justify-between">
      <p class="text-xs text-white/50">
        © {currentYear} {BRAND.legal.company} — {BRAND.legal.address}
      </p>
      <div class="flex gap-6 text-xs">
        <a href="/privacy-policy" class="text-white/50 hover:text-white">Privacy Policy</a>
        <a href="/termini-servizio" class="text-white/50 hover:text-white">Termini di servizio</a>
      </div>
    </div>
  </div>
</footer>
