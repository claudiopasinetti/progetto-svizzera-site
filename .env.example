# ============================================================================
# Progetto Svizzera — env template
# Copy to .env.local for dev, set on Cloudflare Pages dashboard for prod.
# ============================================================================

# --- Analytics (Step 3) ---
# Property GA4 nuova (Beatrice paga via account Language Lab, mail Claudio temp)
PUBLIC_GA4_MEASUREMENT_ID=
# Container GTM (gestisce GA4 + Meta Pixel + altri tag)
PUBLIC_GTM_CONTAINER_ID=
# Meta Pixel ID — vuoto finché BM Eumedica nuovo è sbloccato (post-casting)
PUBLIC_META_PIXEL_ID=

# --- Email transactional (Step 6) ---
# Resend account su selezione@progetto-svizzera.it (DNS DKIM/SPF/DMARC da configurare)
RESEND_API_KEY=
# From verificato su Resend
EMAIL_FROM="Progetto Svizzera <selezione@progetto-svizzera.it>"
# Email destinataria contact form (Barbara + Beatrice in BCC?)
EMAIL_CONTACT_TO=selezione@progetto-svizzera.it

# --- Site URL ---
PUBLIC_SITE_URL=https://progetto-svizzera.it
